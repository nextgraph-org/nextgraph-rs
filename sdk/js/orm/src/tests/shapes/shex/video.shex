# PREFIX ex: <did:ng:z:>
# 
# SELECT ?subject ?predicate ?object WHERE {
#    ?subject ?predicate ?object .
#    ?subject ex:assets ?object .
# } LIMIT 10

PREFIX ex: <did:ng:z:>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ex:MiruVideoDocumentShape {
  a [ex:MiruVideoDocument] ;

  ex:name xsd:string ;
  ex:description xsd:string ? ;
  ex:createdAt xsd:date ;
  ex:assets @ex:MiruMediaAssetShape OR @ex:MiruVideoEffectAssetShape *;
  # ex:assets @ex:MiruMediaAssetShape *;
}

ex:MiruVideoEffectAssetShape EXTRA a {
  a [ex:MiruVideoEffectAsset] ;

  ex:id xsd:string ;
  ex:type [ "asset:effect:video" ] ;
  ex:name xsd:string ;

  ex:ops xsd:string ; # ops array as JSON string
}

ex:MiruMediaAssetShape EXTRA a {
  a [ex:MiruMediaAsset] ;

  ex:id xsd:string ;
  ex:type [ "asset:media:av" ] ;
  ex:name xsd:string ;
  
  ex:mimeType xsd:string ;
  ex:duration xsd:float ;
  ex:size xsd:integer ;
  ex:audio @ex:MiruMediaAssetAudioShape ? ;
  ex:video @ex:MiruMediaAssetVideoShape ? ;
  ex:uri xsd:string OR IRI;
}

ex:MiruMediaAssetAudioShape EXTRA a {
  a [ex:MiruMediaAssetAudio] ;
  ex:codec xsd:string ;
  ex:duration xsd:float ;
  ex:numberOfChannels xsd:integer ;
  ex:sampleRate xsd:integer ;
  ex:firstTimestamp xsd:float ;
}

ex:MiruMediaAssetVideoShape EXTRA a {
  a [ex:MiruMediaAssetVideo] ;
  ex:codec xsd:string ;
  ex:duration xsd:float ;
  ex:rotation xsd:integer ;
  ex:width xsd:integer ;
  ex:height xsd:integer ;
  ex:frameRate xsd:float ;
  ex:firstTimestamp xsd:float ;
}