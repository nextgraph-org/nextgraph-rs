{
  "name": "@ng-org/orm",
  "version": "0.1.2-alpha.12",
  "private": false,
  "type": "module",
  "authors": [
    "Laurin Weger"
  ],
  "license": "MIT/Apache-2.0",
  "main": "./src/core.ts",
  "scripts": {
    "test": "vitest",
    "build:ts": "rm -rf dist && tsc",
    "prepublishOnly": "pnpm build:ts"
  },
  "exports": {
    ".": {
      "default": "./src/core.ts"
    },
    "./all": {
      "default": "./src/index.ts"
    },
    "./react": {
      "default": "./src/frontendAdapters/react/index.ts"
    },
    "./svelte": {
      "default": "./src/frontendAdapters/svelte/index.ts"
    },
    "./svelte4": {
      "default": "./src/frontendAdapters/svelte4/index.ts"
    },
    "./vue": {
      "default": "./src/frontendAdapters/vue/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/core.js",
    "types": "./dist/core.d.ts",
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "./all": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./react": {
        "types": "./dist/frontendAdapters/react/index.d.ts",
        "default": "./dist/frontendAdapters/react/index.js"
      },
      "./svelte": {
        "types": "./dist/frontendAdapters/svelte/index.d.ts",
        "default": "./dist/frontendAdapters/svelte/index.js"
      },
      "./svelte4": {
        "types": "./dist/frontendAdapters/svelte4/index.d.ts",
        "default": "./dist/frontendAdapters/svelte4/index.js"
      },
      "./vue": {
        "types": "./dist/frontendAdapters/vue/index.d.ts",
        "default": "./dist/frontendAdapters/vue/index.js"
      }
    }
  },
  "peerDependencies": {
    "react": "^19.0.0 || ^18.0.0",
    "svelte": "^5.0.0 || ^4.0.0 || ^3.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@ng-org/alien-deepsignals": "workspace:*"
  },
  "devDependencies": {
    "@ng-org/shex-orm": "workspace:*",
    "@ng-org/web": "workspace:*",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "vite": "7.3.1",
    "vitest": "^3.2.4",
    "typescript": "^5.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "svelte": "^5.39.12",
    "vue": "^3.5.19"
  },
  "files": [
    "dist"
  ]
}
